# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
PRESALE_WALLET=YourPresaleWalletPubkey
PROGRAM_ID=DRidePresale11111111111111111111111111
TOKEN_MINT=DRideToken11111111111111111111111111

# Presale Configuration
PRESALE_PRICE=0.005
PRESALE_NEXT_PRICE=0.008
PRESALE_HARD_CAP=1000000
PRESALE_START=2026-04-01T00:00:00Z
PRESALE_END=2026-06-30T23:59:59Z
MAX_PURCHASE_PER_WALLET=1000
TOKENS_PER_SOL=200

# Backend API
BACKEND_API_URL=http://localhost:8080
API_TIMEOUT=30

# Security
JWT_SECRET=YourSecureRandomSecretAtLeast32Chars
CORS_ALLOWED_ORIGINS=https://dride.app,http://localhost:3000
RATE_LIMIT_PER_MINUTE=10
MAX_PURCHASES_PER_DAY=100

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
ENABLE_PRESALE=true
ENABLE_METAMASK=false
ENABLE_KYC=false
